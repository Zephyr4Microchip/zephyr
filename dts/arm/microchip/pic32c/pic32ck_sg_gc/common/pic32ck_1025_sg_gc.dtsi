/ {
	soc {
		flash0: flash@8000000 {
			reg = <0x08000000 DT_SIZE_K(128)>;
			ranges = <0x0 0x08000000 DT_SIZE_K(128)>;
		};

		flash1: flash@c000000 {
			reg = <0x0c000000 DT_SIZE_M(1)>;
			ranges = <0x0 0x0c000000 DT_SIZE_M(1)>;
		};

		sram0: memory@20000000 {
			reg = <0x20000000 DT_SIZE_K(256)>;
		};

		sercom6: sercom@45004000 {
			compatible = "microchip,sercom-g1";
			reg = <0x45004000 0x38>;
			interrupts = <108 0>, <109 0>, <110 0>, <111 0>, <112 0>, <113 0>;
			interrupt-names = "error", "dre", "txc", "rxc", "rxs", "ctsic";
			clocks = <&mclkperiph CLOCK_MCHP_MCLKPERIPH_ID_SERCOM6_APB>,
			<&gclkperiph CLOCK_MCHP_GCLKPERIPH_ID_SERCOM6_CORE>;
			clock-names = "mclk", "gclk";
			status = "disabled";
		};

		sercom7: sercom@45008000 {
			compatible = "microchip,sercom-g1";
			reg = <0x45008000 0x38>;
			interrupts = <114 0>, <115 0>, <116 0>, <117 0>, <118 0>, <119 0>;
			interrupt-names = "error", "dre", "txc", "rxc", "rxs", "ctsic";
			clocks = <&mclkperiph CLOCK_MCHP_MCLKPERIPH_ID_SERCOM7_APB>,
			<&gclkperiph CLOCK_MCHP_GCLKPERIPH_ID_SERCOM7_CORE>;
			clock-names = "mclk", "gclk";
			status = "disabled";
		};
	};
};
